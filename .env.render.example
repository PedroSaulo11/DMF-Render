# Render Postgres deployment template
NODE_ENV=production
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/dmf_app
PG_SSL=false
LOG_TO_CONSOLE=true

JWT_SECRET=generate_a_long_random_secret
SIGNATURE_SECRET=generate_a_long_random_secret
CORS_ORIGINS=https://YOUR-SERVICE.onrender.com

EXTERNAL_API_TIMEOUT_MS=10000
CONTA_AZUL_TIMEOUT_MS=10000
COBLI_TIMEOUT_MS=10000
DB_SCHEMA_STRICT=false

DB_POOL_MAX=10
DB_POOL_MIN=0
DB_POOL_ACQUIRE_MS=30000
DB_POOL_IDLE_MS=10000

CACHE_TTL_SECONDS=60
CACHE_TTL_PAYMENTS=60
CACHE_TTL_COBLI_PAYMENTS=60
CACHE_TTL_COBLI_LOCATIONS=30
ENABLE_REDIS_CACHE=false
ENABLE_DISTRIBUTED_RATE_LIMIT=false
ENABLE_PUBSUB_SSE=false
ENABLE_STRICT_API_ONLY_AUTH=false
ENABLE_HTTPONLY_SESSION=false

PERMISSIONS_ENFORCED=true
ENFORCE_COMPANY_ACCESS=true
ALLOW_ALL_COMPANIES_WHEN_UNSET=false
DEFAULT_COMPANIES=DMF,JFX,Real Energy

ACCESS_TOKEN_EXPIRES_IN=48h
USER_REFRESH_EXPIRES_DAYS=30
LOGIN_LOCK_WINDOW_MS=900000
LOGIN_LOCK_MAX_ATTEMPTS=6
LOGIN_LOCK_DURATION_MS=900000

CONTA_AZUL_CLIENT_ID=
CONTA_AZUL_CLIENT_SECRET=
CONTA_AZUL_ACCESS_TOKEN=
CONTA_AZUL_REFRESH_TOKEN=
CONTA_AZUL_TOKEN_URL=https://api.contaazul.com/oauth2/token
CONTA_AZUL_API_BASE_URL=https://api.contaazul.com
CONTA_AZUL_PAYMENTS_PATH=/v2/payments

COBLI_API_TOKEN=
COBLI_WEBHOOK_SECRET=
COBLI_API_BASE_URL=https://api.cobli.com.br/v2
COBLI_AUTH_HEADER=Authorization
COBLI_AUTH_SCHEME=Bearer
COBLI_WEBHOOK_SIGNATURE_HEADER=X-Cobli-Signature
